generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(cuid())
  username              String                 @unique
  passwordHash          String
  role                  String                 @default("user")
  email                 String?                @unique
  createdAt             DateTime               @default(now())
  reinigungErlaubt      Boolean                @default(false)
  reinigungMaxMinuten   Int                    @default(15)
  mobileDesktopUpload   Boolean                @default(false)
  entries               Entry[]
  vorgaben              TrainingVorgabe[]
  passwordResetTokens   PasswordResetToken[]
  kontrollAnforderungen   KontrollAnforderung[]
  verschlussAnforderungen VerschlussAnforderung[]
  strafeRecords           StrafeRecord[]
  adminRelationships      AdminUserRelationship[] @relation("AdminRelationships")
  userRelationships       AdminUserRelationship[] @relation("UserRelationships")
  pushSubscriptions       PushSubscription[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model TrainingVorgabe {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gueltigAb     DateTime
  gueltigBis    DateTime?
  minProTagH    Float?
  minProWocheH  Float?
  minProMonatH  Float?
  notiz         String?
  createdAt     DateTime  @default(now())

  @@index([userId])
}

model KontrollAnforderung {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  code        String
  kommentar   String?
  deadline    DateTime
  createdAt   DateTime  @default(now())
  fulfilledAt DateTime? // Server-seitig gesetzt beim Erstellen des PRUEFUNG-Eintrags – nie editierbar
  withdrawnAt DateTime?
  entryId     String?   @unique
  entry       Entry?    @relation("KontrolleEntry", fields: [entryId], references: [id], onDelete: SetNull)

  @@index([userId, withdrawnAt])
  @@index([userId, entryId])
}

model VerschlussAnforderung {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  art         String    // "ANFORDERUNG" | "SPERRZEIT"
  nachricht   String?
  endetAt     DateTime? // ANFORDERUNG: Frist zum Einschliessen; SPERRZEIT: darf nicht öffnen bis
  dauerH      Float?    // ANFORDERUNG only: Mindest-Tragedauer (h) – erzeugt nach Einschliessen automatisch SPERRZEIT
  createdAt   DateTime  @default(now())
  fulfilledAt DateTime? // ANFORDERUNG: gesetzt wenn User VERSCHLUSS erstellt
  withdrawnAt DateTime?

  @@index([userId, art, withdrawnAt])
}

// n:m relationship between admins and the users they supervise.
// Additive migration — no existing data is changed.
// Only active when USE_ADMIN_RELATIONSHIPS=true (feature flag).
model AdminUserRelationship {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation("AdminRelationships", fields: [adminId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserRelationships", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([adminId, userId])
  @@index([adminId])
  @@index([userId])
}

// Tracks consumed portal-login JTIs to prevent replay attacks.
// Rows older than 1h are pruned automatically by the portal-login endpoint.
model PortalTokenUsed {
  jti    String   @id
  usedAt DateTime @default(now())
}

// Web Push subscriptions for PWA push notifications.
// One row per browser/device per user; endpoint is the unique push endpoint URL.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Persistent rate limiting — replaces in-memory Maps across all API routes.
// key format: "ip:<ip>" | "user:<userId>" | "login:<username>" | "fp:<ip>"
// Expired rows are deleted on each check (no background job needed for SQLite).
model RateLimit {
  key     String   @id
  count   Int      @default(1)
  resetAt DateTime
}

model StrafeRecord {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  offenseType   String   // "KONTROLLANFORDERUNG" | "OEFFNEN_ENTRY"
  refId         String   @unique
  bestraftDatum DateTime
  notiz         String?
  createdAt     DateTime @default(now())

  @@index([userId])
}

model Entry {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                String               @default("VERSCHLUSS")
  startTime           DateTime
  imageUrl            String?
  imageExifTime       DateTime?
  note                String?
  oeffnenGrund        String?
  orgasmusArt         String?
  kontrollCode        String?
  verifikationStatus  String?
  createdAt           DateTime             @default(now())
  kontrollAnforderung KontrollAnforderung? @relation("KontrolleEntry")

  @@index([userId])
  @@index([userId, type, startTime(sort: Desc)])
}
