generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(cuid())
  username              String                 @unique
  passwordHash          String
  role                  String                 @default("user")
  email                 String?                @unique
  createdAt             DateTime               @default(now())
  reinigungErlaubt      Boolean                @default(false)
  reinigungMaxMinuten   Int                    @default(15)
  entries               Entry[]
  vorgaben              TrainingVorgabe[]
  passwordResetTokens   PasswordResetToken[]
  kontrollAnforderungen   KontrollAnforderung[]
  verschlussAnforderungen VerschlussAnforderung[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model TrainingVorgabe {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gueltigAb     DateTime
  gueltigBis    DateTime?
  minProTagH    Float?
  minProWocheH  Float?
  minProMonatH  Float?
  notiz         String?
  createdAt     DateTime  @default(now())
}

model KontrollAnforderung {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  code        String
  kommentar   String?
  deadline    DateTime
  createdAt   DateTime  @default(now())
  fulfilledAt DateTime? // Server-seitig gesetzt beim Erstellen des PRUEFUNG-Eintrags – nie editierbar
  withdrawnAt DateTime?
  entryId     String?   @unique
  entry       Entry?    @relation("KontrolleEntry", fields: [entryId], references: [id], onDelete: SetNull)
}

model VerschlussAnforderung {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  art         String    // "ANFORDERUNG" | "SPERRZEIT"
  nachricht   String?
  endetAt     DateTime? // ANFORDERUNG: Deadline zum Einschliessen; SPERRZEIT: darf nicht öffnen bis
  dauerH      Float?    // ANFORDERUNG only: Mindestdauer in Stunden nach Einschliessen
  createdAt   DateTime  @default(now())
  fulfilledAt DateTime? // ANFORDERUNG: gesetzt wenn User VERSCHLUSS erstellt
  withdrawnAt DateTime?
}

// n:m relationship between admins and the users they supervise.
// Additive migration — no existing data is changed.
// Only active when USE_ADMIN_RELATIONSHIPS=true (feature flag).
model AdminUserRelationship {
  id        String   @id @default(cuid())
  adminId   String
  userId    String
  createdAt DateTime @default(now())

  @@unique([adminId, userId])
  @@index([adminId])
  @@index([userId])
}

model Entry {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                String               @default("VERSCHLUSS")
  startTime           DateTime
  imageUrl            String?
  imageExifTime       DateTime?
  note                String?
  oeffnenGrund        String?
  orgasmusArt         String?
  kontrollCode        String?
  verifikationStatus  String?
  createdAt           DateTime             @default(now())
  kontrollAnforderung KontrollAnforderung? @relation("KontrolleEntry")

  @@index([userId])
  @@index([userId, type])
}
